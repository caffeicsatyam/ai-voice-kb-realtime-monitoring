# === AI Voice ADK Assessment - Environment Variables ===

# Google API Key for Gemini (required for primary ADK agents)
GOOGLE_API_KEY=your_google_api_key_here

# Groq fallback via LangChain (optional; used if ADK/model calls fail)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2

# Model configuration
ADK_MODEL=gemini-3.0
ADK_TEMPERATURE=0.3

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Knowledge Base
KB_RECORDS_PATH=knowledge_base/records.jsonl
KB_CHUNKS_PATH=knowledge_base/chunks.jsonl
KB_INDEX_PATH=knowledge_base/bm25_index.json
KB_TOP_K=5

# Retrieval
RETRIEVAL_CONFIDENCE_THRESHOLD=0.3

# Real-time Nudges
NUDGE_CONFIDENCE_THRESHOLD=0.7
NUDGE_COOLDOWN_SECONDS=15
NUDGE_EXPIRY_SECONDS=30
NUDGE_MAX_PER_MINUTE=4

# ASR (optional - set to "browser" to use Web Speech API)
ASR_PROVIDER=browser
# ASR_PROVIDER=whisper
# WHISPER_MODEL=base

# TTS (browser = Web SpeechSynthesis, edge = Edge TTS)
TTS_PROVIDER=browser

# Logging
LOG_LEVEL=INFO
EVIDENCE_DIR=evidence
